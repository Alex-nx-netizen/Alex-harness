# Alex-harness — keep skill runtime artifacts out of git
skills/*/logs/
skills/*/tmp/

# Helix runtime state
_meta/.helix-current-run.json
_meta/live-events.jsonl
_meta/repo-ctx-snapshot.json
_tmp_repo_ctx.json
_tmp_sr_record.json

# Mode-router runtime log — fixture data 可能含外部业务情境，避免泄露
_meta/mode-router-log.jsonl

# Playwright MCP runtime
.playwright-mcp/

# Node
node_modules/
*.log

# OS
.DS_Store
Thumbs.db

# Context-curator machine output (snapshots regenerated each run)
_meta/context-snapshots/

# v0.7 e2e fixtures: replay output regenerated each run
_meta/e2e-fixtures/.last-replay-report.json

# v0.7 cron heartbeat log (local-only by default)
_meta/heartbeat.log

# v0.7 archive (rotation output)
_meta/archive/

# v0.8 dogfood suite report (regenerated each run)
_meta/dogfood/last-suite-report.json

# v0.9.1：rotate / migrate 安全备份不进 git（本机临时文件）
*.bak
*.bak-*

# v0.9.1：Claude Code 本机权限配置含本机路径，不进 git
.claude/settings.local.json
